}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/created" : [ {
    "@value" : "2026-04-15"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Daniel Doña"
  }, {
    "@value" : "Edna Ruckhaus"
  }, {
    "@value" : "Lucía Sánchez"
  }, {
    "@value" : "Oscar Corcho"
  }, {
    "@value" : "Socorro Bernardos"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "es",
    "@value" : "El propósito de esta ontología es proporcionar un vocabulario común para la representación de las entidades y los datos principales relacionados con los establecimientos comerciales de un municipio y sus licencias."
  }, {
    "@language" : "en",
    "@value" : "The purpose of this ontology is to provide a common vocabulary for representing the main entities and data related to a municipality's commecial spaces and their permits."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "es",
    "@value" : "Ontología de Establecimiento Comercial"
  }, {
    "@language" : "en",
    "@value" : "The Commercial Establishment Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "edintcom"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.1.0"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#CommercialAggregation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "La integración de varios establecimientos o puntos de venta en un mismo espacio físico, como centros comerciales o mercados."
  }, {
    "@language" : "en",
    "@value" : "The integration of several establishments or points of sale in the same physical space, such as shopping centers or markets."
