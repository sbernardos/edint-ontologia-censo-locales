@base <http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#> .

<http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales> rdf:type owl:Ontology ;
                                                                       owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales/0.1.0> ;
                                                                       <http://purl.org/dc/terms/created> "2026-04-15" ;
                                                                       <http://purl.org/dc/terms/creator> "Daniel Doña" ,
                                                                                                          "Edna Ruckhaus" ,
                                                                                                          "Lucía Sánchez" ,
                                                                                                          "Oscar Corcho" ,
                                                                                                          "Socorro Bernardos" ;
                                                                       <http://purl.org/dc/terms/description> "El propósito de esta ontología es proporcionar un vocabulario común para la representación de las entidades y los datos principales relacionados con los establecimientos comerciales de un municipio y sus licencias."@es ,
                                                                                                              "The purpose of this ontology is to provide a common vocabulary for representing the main entities and data related to a municipality's commecial spaces and their permits."@en ;
                                                                       <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                       <http://purl.org/dc/terms/title> "Ontología de Establecimiento Comercial"@es ,
                                                                                                        "The Commercial Establishment Ontology"@en ;
                                                                       <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintcom" ;
                                                                       <http://purl.org/vocab/vann/preferredNamespaceUri> : ;
                                                                       owl:versionInfo "0.1.0" .

