                                                                                                                                                   ]
                                                                                                                                                 ) ;
                                                                                                                              rdf:type owl:Class
                                                                                                                            ] ;
                                                                                                                 rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/infraestructura#> .


