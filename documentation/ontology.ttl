###  http://schema.org/address
<http://schema.org/address> rdf:type owl:ObjectProperty ;
                            rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo> rdf:type owl:ObjectProperty ,
                                                                            owl:FunctionalProperty ;
                                                                   rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                   rdfs:range <http://www.opengis.net/ont/sf#Point> ;
                                                                   rdfs:comment "Relación del tramo con el lugar donde finaliza el tramo."@es ,
                                                                                "Relationship of the section with the point where it ends."@en ;
                                                                   rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                   rdfs:label "Fin del Tramo"@es ,
                                                                              "Section end"@en .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo> rdf:type owl:ObjectProperty ,
                                                                               owl:FunctionalProperty ;
                                                                      rdfs:domain <http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> ;
                                                                      rdfs:range <http://www.opengis.net/ont/sf#Point> ;
                                                                      rdfs:comment "Relación del tramo con el lugar donde se inicia el tramo."@es ,
                                                                                   "Relationship of the section with the point where it starts."@en ;
                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                      rdfs:label "Inicio del Tramo"@es ,
                                                                                 "Section start"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#appliedTo
:appliedTo rdf:type owl:ObjectProperty ;
           rdfs:comment "It relates an entity, especially a commercial permit, to the entity, especially a commercial space, to which it is applied."@en ,
                        "Relaciona una entidad, principalmente una licencia comercial, con la entidad, principalmente un espacio comercial, a la que se aplica."@es ;
           rdfs:label "aplicada a"@es ,
                      "applied to"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#belongsToCommercialAggregation
:belongsToCommercialAggregation rdf:type owl:ObjectProperty ;
                                rdfs:range :CommercialAggregation ;
                                rdfs:comment "It relates an entity, especially a commercial space, to the commercial aggregation, to which it belongs."@en ,
                                             "Relaciona una entidad, principalmente un espacio comercial, con la agrupación comercial a la que pertenece."@es ;
                                rdfs:label "belongs to commercial aggregation"@en ,
                                           "pertenece a agrupación comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCNAECode
:hasCNAECode rdf:type owl:ObjectProperty ;
             rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                 owl:hasValue <http://lod.ine.es/clasificaciones/cnae/CNAE-2025>
                                               ]
                                             ) ;
                          rdf:type owl:Class
                        ] ;
             rdfs:comment "It relates an entity, especially a commercial entity or permit, to a skos concept that is in the CNAE taxonomy."@en ,
                          "Relaciona una entidad, principalmente una entidad o licencia comercial, con un concepto skos que está en la taxonomía de códigos CNAE."@es ;
             rdfs:label "has CNAE code"@en ,
                        "tiene código CNAE"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialPermitStatus
:hasCommercialPermitStatus rdf:type owl:ObjectProperty ;
                           rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                               owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialPermitStatus>
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                           rdfs:comment "It relates an entity, especially a commercial permit, to a skos concept that is in the commercial permit status taxonomy."@en ,
                                        "Relaciona una entidad, principalmente una licencia comercial, con un concepto skos que está en la taxonomía de estado de la licencia comercial."@es ;
                           rdfs:label "has commercial permit status"@en ,
                                      "tiene estado de la licencia comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialPermitType
:hasCommercialPermitType rdf:type owl:ObjectProperty ;
                         rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                             owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialPermitType>
                                                           ]
                                                         ) ;
                                      rdf:type owl:Class
                                    ] ;
                         rdfs:comment "It relates an entity, especially a commercial permit, to a skos concept that is in the commercial permit type taxonomy."@en ,
                                      "Relaciona una entidad, principalmente una licencia comercial, con un concepto skos que está en la taxonomía de tipo de licencia comercial."@es ;
                         rdfs:label "has commercial permit type"@en ,
                                    "tiene tipo de licencia comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialSpaceStatus
:hasCommercialSpaceStatus rdf:type owl:ObjectProperty ;
                          rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                              owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialSpaceStatus>
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                          rdfs:comment "It relates an entity, especially a commercial space, to a skos concept that is in the commercial space status taxonomy."@en ,
                                       "Relaciona una entidad, principalmente un espacio comercial, con un concepto skos que está en la taxonomía de situación del espacio comercial."@es ;
                          rdfs:label "has commercial space status"@en ,
                                     "tiene situación del espacio comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasIAECode
:hasIAECode rdf:type owl:ObjectProperty ;
            rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/IAE>
                                              ]
                                            ) ;
                         rdf:type owl:Class
                       ] ;
            rdfs:comment "Relaciona una entidad, principalmente una entidad o licencia comercial, con un concepto skos que está en la taxonomía de códigos IAE."@es ,
                         "It relates an entity, especially a commercial entity or permit, to a skos concept that is in the IAE taxonomy." ;
            rdfs:label "has IAE code"@en ,
                       "tiene código IAE"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasTerrace
:hasTerrace rdf:type owl:ObjectProperty ;
            rdfs:range :Terrace ;
            rdfs:comment "It relates an entity, especially a commercial space, to a terrace it has."@en ,
                         "Relaciona una entidad, principalmente un espacio comercial, con una terraza que tiene."@es ;
            rdfs:label "has terrace"@en ,
                       "tiene terraza"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasTerracePeriod
:hasTerracePeriod rdf:type owl:ObjectProperty ;
                  rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                    [ rdf:type owl:Restriction ;
                                                      owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
                                                      owl:hasValue <http://vocab.linkeddata.es/datosabiertos/kos/edint/TerracePeriod>
                                                    ]
                                                  ) ;
                               rdf:type owl:Class
                             ] ;
                  rdfs:comment "It relates an entity, especially a terrace, to a skos concept that is in the terrace period taxonomy."@en ,
                               "Relaciona una entidad, principalmente una terrazal, con un concepto skos que está en la taxonomía de periodo de funcionamiento de la terraza."@es ;
                  rdfs:label "has terrace period"@en ,
                             "tiene periodo de funcionamiento de la terraza"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#issuedTo
:issuedTo rdf:type owl:ObjectProperty ;
          rdfs:comment "It relates an entity, especially a commercial permit, to the entity, especially a commercial entity, to which (or whom) it is issued."@en ,
                       "Relaciona una entidad, principalmente una licencia comercial, con la entidad, principalmente una entidad comercial, para la que se emite."@es ;
          rdfs:label "emitida para"@es ,
                     "issued to"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone
:locatedInZone rdf:type owl:ObjectProperty ;
               rdfs:comment "It relates en entity, especially a commercial space, event or campaign, to the zone where it is."@en ,
                            "Relaciona una entidad, principalmente un espacio, campaña o evento comercial, con la zona en la que está."@es ;
               rdfs:label "located in zone"@en ,
                          "situado en zona"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#usesSpace
:usesSpace rdf:type owl:ObjectProperty ;
           rdfs:comment "It relates an entity, especially a commercial entity, to a commercial space it uses."@en ,
                        "Relaciona una entidad, principalmente una entidad comercial, con un espacio comercial que emplea."@es ;
           rdfs:label "usa espacio"@es ,
                      "uses space"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                   rdfs:comment "Municipio al que pertenece un fenómeno geográfico o una entidad administrativa"@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "pertenece a municipio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal> rdf:type owl:ObjectProperty ;
                                                                                                   rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal> ;
                                                                                                   rdfs:comment "Portal que un fenómeno geográfico contiene (por ejemplo, una vía o un tramo de vía, aunque también puede ser un barrio, distrito, ciudad, etc.)"@es ;
                                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                                   rdfs:label "contiene portal"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia> rdf:type owl:ObjectProperty ;
                                                                                                rdfs:subPropertyOf <http://www.opengis.net/ont/geosparql#sfContains> ;
                                                                                                rdfs:range <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> ;
                                                                                                <http://purl.org/dc/terms/issued> "2014-03-28" ;
                                                                                                rdfs:comment "Vía que un fenómeno geográfico contiene (por ejemplo, un barrio, distrito, ciudad, etc.)"@es ;
                                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                                rdfs:label "contiene vía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismos-infraestructuras/infraestructura#hasInfrastructureType
<http://vocab.linkeddata.es/datosabiertos/def/urbanismos-infraestructuras/infraestructura#hasInfrastructureType> rdf:type owl:ObjectProperty ;
                                                                                                                 rdfs:range [ owl:intersectionOf ( <http://www.w3.org/2004/02/skos/core#Concept>
                                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                                     owl:onProperty <http://www.w3.org/2004/02/skos/core#inScheme> ;
