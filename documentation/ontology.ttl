                                     rdfs:subPropertyOf <http://www.w3.org/2006/time#hasTime> ;
                                     rdfs:comment "End of a temporal entity."@en ,
                                                  "Final de una entidad temporal."@es ;
                                     rdfs:label "has end"@en ,
                                                "tiene fin"@es ;
                                     <http://www.w3.org/2004/02/skos/core#definition> "End of a temporal entity."@en ,
                                                                                      "Final de una entidad temporal."@es .


###  http://www.w3.org/2006/time#hasTime
<http://www.w3.org/2006/time#hasTime> rdf:type owl:ObjectProperty .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:range rdfs:Literal ;
                                      rdfs:comment "An unambiguous reference to the resource within a given context."@en ,
                                                   "Una referencia no ambigüa al recurso dentro de un contexto determinado."@es ;
                                      rdfs:isDefinedBy <http://purl.org/dc/terms/> ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  http://schema.org/endDate
<http://schema.org/endDate> rdf:type owl:DatatypeProperty ;
                            rdfs:range xsd:dateTime ;
                            rdfs:comment "La fecha y hora de finalización del elemento (en formato de fecha ISO 8601)."@es ,
                                         "The end date and time of the item (in ISO 8601 date format)."@en ,
                                         "end date"@en ;
                            rdfs:isDefinedBy <http://schema.org> ;
                            rdfs:label "fecha de finalización"@es .


###  http://schema.org/floorSize
<http://schema.org/floorSize> rdf:type owl:DatatypeProperty ;
                              rdfs:isDefinedBy <http://schema.org/> .


###  http://schema.org/maximumAttendeeCapacity
<http://schema.org/maximumAttendeeCapacity> rdf:type owl:DatatypeProperty ;
                                            rdfs:isDefinedBy <http://schema.org/> .


###  http://schema.org/openingHours
<http://schema.org/openingHours> rdf:type owl:DatatypeProperty ;
                                 rdfs:domain :Facility ;
                                 rdfs:range xsd:string ;
                                 rdfs:comment "Horario general de apertura de un negocio. El horario se puede especificar como un rango semanal, comenzando por días y luego por horas al día. Se pueden indicar varios días separados por comas (\",\"). Los rangos de días u horas se especifican con un guion (-)."@es ,
                                              "The general opening hours for a business. Opening hours can be specified as a weekly time range, starting with days, then times per day. Multiple days can be listed with commas ',' separating each day. Day or time ranges are specified using a hyphen '-'."@en ;
                                 rdfs:isDefinedBy <http://schema.org> ;
                                 rdfs:label "horario de apertura"@es ,
                                            "opening hours"@en .


###  http://schema.org/startDate
<http://schema.org/startDate> rdf:type owl:DatatypeProperty ;
                              rdfs:range xsd:dateTime ;
                              rdfs:comment "La fecha y hora de inicio del elemento (en formato de fecha ISO 8601)."@es ,
                                           "The start date and time of the item (in ISO 8601 date format)."@en ;
                              rdfs:isDefinedBy <http://schema.org> ;
                              rdfs:label "fecha de inicio"@es ,
                                         "start date"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#fileCode
:fileCode rdf:type owl:DatatypeProperty ;
          rdfs:comment "Indica el código del expediente de una entidad, especialmente una licencia."@es ,
                       "It captures the file code of  an entity, especilly a permit."@en ;
          rdfs:label "código del expediente"@es ,
                     "file code"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#installationDate
:installationDate rdf:type owl:DatatypeProperty ;
                  rdfs:domain :UrbanElement ;
                  rdfs:range xsd:dateTime ;
                  rdfs:comment "Date when an entity, especially a device, was installed."@en ,
                               "Fecha en la que se instaló una entidad, especialmente un dispositivo"@es ;
                  rdfs:label "fecha de instalación"@es ,
                             "installation date"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#maintenanceDate
:maintenanceDate rdf:type owl:DatatypeProperty ;
                 rdfs:domain :UrbanElement ;
                 rdfs:range xsd:dateTime ;
                 rdfs:comment "Date when an entity was last maintained, especially an urban element."@en ,
                              "Fecha en la que se hizo mantenimiento de una entidad por última vez, especialmente un elemento urbano."@es ;
                 rdfs:label "fecha de mantenimiento"@es ,
                            "maintenance date"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#numberOfPermitedChairs
:numberOfPermitedChairs rdf:type owl:DatatypeProperty ;
                        rdfs:comment "Indica el número máximo de sillas que puede tener una entidad, principalmente una terraza."@es ,
                                     "It captures the maximum number of chairs an entity, especially a terrace, can have."@en ;
                        rdfs:label "number of permited chairs"@en ,
                                   "número de sillas autorizadas"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#numberOfPermitedTables
:numberOfPermitedTables rdf:type owl:DatatypeProperty ;
                        rdfs:comment "Indica el número máximo de mesas que puede tener una entidad, principalmente una terraza."@es ,
                                     "It captures the maximun number of tables an entity, especially a terrace, can have."@en ;
                        rdfs:label "number of permited tables"@en ,
                                   "número de mesas autorizadas"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#public
:public rdf:type owl:DatatypeProperty ;
        rdfs:range xsd:boolean ;
        rdfs:comment "Indica si una entidad del censo de locales comerciales es pública o no."@es ,
                     "It points out whether an entity in the commerce census is public or not"@en ;
        rdfs:label "public"@en ,
                   "público"@es .


###  http://www.w3.org/2006/time#inXSDgYearMonth
<http://www.w3.org/2006/time#inXSDgYearMonth> rdf:type owl:DatatypeProperty ;
                                              rdfs:range xsd:gYearMonth ;
                                              rdfs:comment "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                           "Position of an instant, expressed using xsd:gYearMonth"@en ;
                                              rdfs:isDefinedBy <http://www.w3.org/2006/time#> ;
                                              rdfs:label "en año-mes gregoriano XSD"@es ,
                                                         "in XSD g-YearMonth"@en ;
                                              <http://www.w3.org/2004/02/skos/core#definition> "Posición de un instante, expresado utilizando xsd:gYearMonth."@es ,
                                                                                               "Position of an instant, expressed using xsd:gYearMonth"@en .


###  https://datos.ign.es/def/geo_core#xETRS89
<https://datos.ign.es/def/geo_core#xETRS89> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.opengis.net/ont/sf#Point> ;
                                            rdfs:range xsd:float ;
                                            <http://purl.org/dc/elements/1.1/source> "Catálogo de Objetos Geográficos BTN100."@es ;
                                            rdfs:comment "Coordenada X en metros (ETRS89)"@es ,
                                                         "X-Coordinate in meters (ETRS89)"@en ;
                                            rdfs:isDefinedBy <https://datos.ign.es/def/geo_core#> ;
                                            rdfs:label "xETRS89" .


###  https://datos.ign.es/def/geo_core#yETRS89
<https://datos.ign.es/def/geo_core#yETRS89> rdf:type owl:DatatypeProperty ;
                                            rdfs:domain <http://www.opengis.net/ont/sf#Point> ;
                                            rdfs:range xsd:float ;
                                            <http://purl.org/dc/elements/1.1/source> "Catálogo de Objetos Geográficos BTN100."@es ;
                                            rdfs:comment "Coordenada Y en metros (ETRS89)"@es ,
                                                         "Y-Coordinate in meters (ETRS89)"@en ;
                                            rdfs:isDefinedBy <https://datos.ign.es/def/geo_core#> ;
                                            rdfs:label "yETRS89" .


#################################################################
#    Classes
#################################################################

###  http://schema.org/Person
<http://schema.org/Person> rdf:type owl:Class ;
                           rdfs:isDefinedBy <http://schema.org/> ;
                           rdfs:label "Person"@en ,
                                      "Persona"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta
<http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica#EstacionBicicleta> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf :Facility ;
                                                                                      rdfs:comment "Lugar donde se puede tanto dejar como recoger las bicicletas. Está compuesto de anclajes"@es ;
                                                                                      rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/bicicleta-publica> ;
                                                                                      rdfs:label "Estación de bicicletas"@es .


###  http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo
<http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo> rdf:type owl:Class ;
                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                rdfs:comment "Section/s of a Track defined by a starting and an ending Point."@en ,
                                                                             "Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías"@es ;
                                                                rdfs:isDefinedBy <http://vocab.ciudadesabiertas.es/def/transporte/trafico> ;
                                                                rdfs:label "Section of Track"@en ,
                                                                           "Tramo"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#CommercialAggregation
:CommercialAggregation rdf:type owl:Class ;
                       rdfs:subClassOf :Facility ;
                       rdfs:comment "La integración de varios establecimientos o puntos de venta en un mismo espacio físico, como centros comerciales o mercados."@es ,
                                    "The integration of several establishments or points of sale in the same physical space, such as shopping centers or markets."@en ;
                       rdfs:label "Agrupación comercial"@es ,
                                  "Commercial Aggregation"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#CommercialEntity
:CommercialEntity rdf:type owl:Class ;
                  owl:equivalentClass [ rdf:type owl:Class ;
                                        owl:unionOf ( <http://schema.org/Person>
                                                      <https://schema.org/Organization>
                                                    )
                                      ] ;
                  rdfs:comment "Person and/or organization that plays an economic activity and that is assigned the permit of a commercial space."@en ,
                               "Ppersona u organización que realiza una actividad económica y a quien se asigna la licencia de un espacio comercial"@es ;
                  rdfs:label "Commercial entity"@en ,
                             "Entidad comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#CommercialSpace
:CommercialSpace rdf:type owl:Class ;
                 rdfs:subClassOf :Facility ;
                 rdfs:comment "Lugar físico preparado para la venta de productos, prestación de servicios o atención al cliente, tales como tiendas, locales u oficinas."@es ,
                              "Physical place prepared for the sale of products, provision of services or customer service, such as stores or  offices." ;
                 rdfs:label "Commercial space"@en ,
                            "Espacio comercial"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#Facility
:Facility rdf:type owl:Class ;
          rdfs:subClassOf :InfrastructureElement ;
          rdfs:comment "Hace referencia a edificios de servicios (públicos o privados), zonas de ocio, zonas comerciales o cualquier otro elemento  que afecte directamente a la movilidad, actuando como un foco de atracción de personas o vehículos."@es ,
                       "It refers to service buildings (public or private), leisure areas, commercial areas or any other element that directly affects mobility, acting as a focus of attraction for persons or vehicles."@en ;
          rdfs:label "Equipamiento"@es ,
                     "Facility"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#InfrastructureElement
:InfrastructureElement rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                       rdfs:comment "Representa el conjunto de todos los elementos de la infraestructura que generan movilidad y elementos urbanos tales como semáforos, señales viales, pilonas, etc."@es ,
                                    "Represents the set of all infrastructure elements that generate mobility and urban elements such as traffic lights, road signs, bollards, etc."@en ;
                       rdfs:label "Elemento de la infraestructura"@es ,
                                  "Infrastructure element"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#Permit
:Permit rdf:type owl:Class ;
        rdfs:comment "It stands for the license of a commercial space"@en ,
                     "Representa la autorización de un espacio comercial"@es ;
        rdfs:label "Licencia"@es ,
                   "Permit"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#Terrace
:Terrace rdf:type owl:Class ;
         rdfs:subClassOf :Facility ;
         rdfs:comment "An open area connected to a bar, restaurant, etc., and serving as an outdoor sitting area for clients"@en ,
                      "Terreno situado delante de un café, bar, restaurante, etcétera, acotado para que los clientes puedan sentarse al aire libre."@es ;
         rdfs:label "Terrace"@en ,
                    "Terraza"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#UrbanElement
:UrbanElement rdf:type owl:Class ;
              rdfs:subClassOf :InfrastructureElement ;
              rdfs:comment "Comprende el inventario de elementos urbanos tales como señales viales, semáforos, pilonas, etc."@es ,
                           "It includes the inventory of urban elements such as road signs, traffic lights, bollards, etc."@en ;
              rdfs:label "Elemento urbano"@es ,
                         "Urban element"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#CommercialZone
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#CommercialZone> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone> .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone> ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/common/zone#> .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#IndustrialZone
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#IndustrialZone> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone> ;
                                                                          rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/common/zone#> .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#LeisureZone
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#LeisureZone> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone> ;
                                                                       rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/common/zone#> .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#RegulatedZone> rdf:type owl:Class ;
                                                                         rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/common/zone#> .


###  http://vocab.linkeddata.es/datosabiertos/def/common/zone#StreetVendingZone
<http://vocab.linkeddata.es/datosabiertos/def/common/zone#StreetVendingZone> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/common/zone#EconomicInterestZone> ;
                                                                             rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/common/zone#> .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Autonomia> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment "Comunidad Autónoma o Ciudad Autónoma"@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Autonomía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Barrio> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                rdfs:comment "Un barrio es cada una de las partes en que se dividen los pueblos grandes o sus distritos [fuente: Diccionario de la Real Academia (DRAE) 2011]"@es ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                rdfs:label "Barrio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Ciudad> rdf:type owl:Class ;
                                                                                rdfs:subClassOf <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> ;
                                                                                rdfs:comment "Una ciudad es un área urbana en la que predominan fundamentalmente la industria y los servicios [fuente: Wikipedia]"@es ;
                                                                                rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                rdfs:label "Ciudad" .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Distrito> rdf:type owl:Class ;
                                                                                  rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                  rdfs:comment "Un distrito es cada una de las demarcaciones en que se subdivide un territorio o una población para distribuir y ordenar el ejercicio de los derechos civiles y políticos, o de las funciones públicas, o de los servicios administrativos [fuente: Diccionario de la Real Academia (DRAE) 2011]"@es ;
                                                                                  rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                  rdfs:label "Distrito"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment """Un Municipio es el ente local definido en el artículo 140 de la Constitución española y la entidad básica de la organización territorial del Estado según el artículo 1 de la Ley 7/1985, de 2 de abril, Reguladora de las Bases del Régimen Local. Tiene personalidad jurídica y plena capacidad para el cumplimiento de sus fines. La delimitación territorial de Municipio está recogida del REgistro Central de Cartografía del IGN.
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do"""@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Municipio"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia
<http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Provincia> rdf:type owl:Class ;
                                                                                   rdfs:subClassOf <http://www.opengis.net/ont/geosparql#Feature> ;
                                                                                   rdfs:comment """Entidad local con personalidad jurídica propia, determinada por la agrupación de Municipios y división territorial para el cumplimiento de las actividades del Estado. La delimitación territorial de Provincia está recogida en el Registro Central de Cartografía del IGN [fuente: Modelo de Direcciones de la Administración General del Estado v.2]
Su identificador, que se especifica con la propiedad dct:identifier, es el proporcionado por el INE en http://www.ine.es/daco/daco42/codmun/codmun09/09codmun.xls
Su nombre, que se especifica con la propiedad dct:title, es el proporcionado por el Registro de Entidades Locales del Ministerio de Política Territorial, en http://www.ine.es/nomen2/index.do"""@es ;
                                                                                   rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio> ;
                                                                                   rdfs:label "Provincia" .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/aparcamiento#Parking> rdf:type owl:Class ;
                                                                                               rdfs:subClassOf :Facility ;
                                                                                               rdfs:comment "Aparcamiento para diferentes tipos de vehículo que incluye instalaciones o superficies de aparcamiento fuera de la vía pública o zonas de aparcamiento en la vía pública para residentes, no residentes o libres."@es ,
                                                                                                            "Parking for different types of vehicles, including off-street parking facilities or on-street parking zones for residents, non-residents, or free parking."@en ;
                                                                                               rdfs:label "Aparcamiento"@es ,
                                                                                                          "Parking"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal> rdf:type owl:Class ;
                                                                                           owl:disjointWith <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> ;
                                                                                           rdfs:comment "Subacceso independiente exterior (al aire libre) a una misma construcción. Para una misma construcción, con un mismo número de vía, pueden existir varias entradas que pueden estar numeradas con números o letras. [fuente: Modelo de Direcciones de la Administración General del Estado v.2]"@es ;
                                                                                           rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                           rdfs:label "Portal" .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Via> rdf:type owl:Class ;
                                                                                        rdfs:subClassOf <http://www.geonames.org/ontology#Feature> ,
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.geonames.org/ontology#featureClass> ;
                                                                                                          owl:hasValue <http://www.geonames.org/ontology#R>
                                                                                                        ] ,
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://www.geonames.org/ontology#featureCode> ;
                                                                                                          owl:hasValue <http://www.geonames.org/ontology#R.ST>
                                                                                                        ] ;
                                                                                        <http://purl.org/dc/terms/issued> "2013-03-28"^^xsd:dateTime ;
                                                                                        rdfs:comment """Vía de comunicación construida para la circulación. 
En su definición según el modelo de direcciones de la Administración General del Estado, Incluye calles, carreteras de todo tipo, caminos, vías de agua, pantalanes, etc. Asimismo, incluye la pseudovía., es decir todo aquello que complementa o sustituye a la vía.
En nuestro caso, este término se utiliza para hacer referencia a las vías urbanas.

Por esta razón, se utiliza geonames:R.ST como valor principal de la propiedad geonames:featureCode, dejando de lado otras opciones como R.PRMN (promenade), R.TRL (trail). Quizás en el futuro haya que relajar un poco esta opción, sobre todo, por ejemplo, para ciudades con costa y paseo marítimo."""@es ;
                                                                                        rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ;
                                                                                        rdfs:label "Vía"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal
<http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal> rdf:type owl:Class ;
                                                                                                           rdfs:comment """Una dirección postal en España. Se define como una especialización de las clases vcard:Address, schema:PostalAddress y locn:Address
Además de las propiedades asociadas a estas clases, y definidas en su correspondiente vocabulario, también se pueden utilizar las definidas en los vocabularios de división administrativa española y en el callejero"""@es ;
                                                                                                           rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal> ;
                                                                                                           rdfs:label "Dirección postal"@es .


###  http://www.geonames.org/ontology#Feature
<http://www.geonames.org/ontology#Feature> rdf:type owl:Class .


###  http://www.opengis.net/ont/geosparql#Feature
<http://www.opengis.net/ont/geosparql#Feature> rdf:type owl:Class ;
                                               rdfs:comment "Esta clase representa el tipo \"feature\" de nivel superior. Es equivalente a GFI_Feature, definida en la norma ISO 19156:2011, y es la superclase de todos los tipos de \"feature\"."@es ;
                                               rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ;
                                               rdfs:label "Feature"@en .


###  http://www.opengis.net/ont/geosparql#Geometry
<http://www.opengis.net/ont/geosparql#Geometry> rdf:type owl:Class ;
                                                rdfs:comment "La clase representa el tipo de geometría de nivel superior. Esta clase es equivalente a la clase UML GM_Object definida en la norma ISO 19107 y es la superclase de todos los tipos de geometría."@es ;
                                                rdfs:isDefinedBy <http://www.opengis.net/spec/geosparql/1.0> ,
                                                                 "Geometría"@es ;
                                                rdfs:label "Geometry"@en .


###  http://www.opengis.net/ont/sf#Point
<http://www.opengis.net/ont/sf#Point> rdf:type owl:Class ;
                                      rdfs:isDefinedBy <http://www.opengis.net/ont/sf#> .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class ;
                                              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core#> .


###  http://www.w3.org/2004/02/skos/core#ConceptScheme
<http://www.w3.org/2004/02/skos/core#ConceptScheme> rdf:type owl:Class ;
                                                    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core#> .


###  https://schema.org/Organization
<https://schema.org/Organization> rdf:type owl:Class ;
                                  rdfs:comment "An organization such as a school, NGO, corporation, club, etc."@en ,
                                               "Una organización como una escuela, una ONG, una corporación, un club, etc."@es ;
                                  rdfs:label "Organización"@es ,
                                             "Organization"@en .


#################################################################
