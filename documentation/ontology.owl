        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialPermitType"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial permit, to a skos concept that is in the commercial permit type taxonomy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una licencia comercial, con un concepto skos que está en la taxonomía de tipo de licencia comercial.</rdfs:comment>
        <rdfs:label xml:lang="en">has commercial permit type</rdfs:label>
        <rdfs:label xml:lang="es">tiene tipo de licencia comercial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialSpaceStatus -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialSpaceStatus">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
