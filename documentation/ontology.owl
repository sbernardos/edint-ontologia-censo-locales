    <!-- http://schema.org/address -->


    <owl:ObjectProperty rdf:about="http://schema.org/address">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/direccion-postal#DireccionPostal"/>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#finTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:comment xml:lang="es">Relación del tramo con el lugar donde finaliza el tramo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the section with the point where it ends.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Fin del Tramo</rdfs:label>
        <rdfs:label xml:lang="en">Section end</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo -->


    <owl:ObjectProperty rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#inicioTramo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/sf#Point"/>
        <rdfs:comment xml:lang="es">Relación del tramo con el lugar donde se inicia el tramo.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship of the section with the point where it starts.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
        <rdfs:label xml:lang="es">Inicio del Tramo</rdfs:label>
        <rdfs:label xml:lang="en">Section start</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#appliedTo -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#appliedTo">
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial permit, to the entity, especially a commercial space, to which it is applied.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una licencia comercial, con la entidad, principalmente un espacio comercial, a la que se aplica.</rdfs:comment>
        <rdfs:label xml:lang="es">aplicada a</rdfs:label>
        <rdfs:label xml:lang="en">applied to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#belongsToCommercialAggregation -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#belongsToCommercialAggregation">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#CommercialAggregation"/>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial space, to the commercial aggregation, to which it belongs.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente un espacio comercial, con la agrupación comercial a la que pertenece.</rdfs:comment>
        <rdfs:label xml:lang="en">belongs to commercial aggregation</rdfs:label>
        <rdfs:label xml:lang="es">pertenece a agrupación comercial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCNAECode -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCNAECode">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://lod.ine.es/clasificaciones/cnae/CNAE-2025"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial entity or permit, to a skos concept that is in the CNAE taxonomy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una entidad o licencia comercial, con un concepto skos que está en la taxonomía de códigos CNAE.</rdfs:comment>
        <rdfs:label xml:lang="en">has CNAE code</rdfs:label>
        <rdfs:label xml:lang="es">tiene código CNAE</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialPermitStatus -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialPermitStatus">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialPermitStatus"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial permit, to a skos concept that is in the commercial permit status taxonomy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una licencia comercial, con un concepto skos que está en la taxonomía de estado de la licencia comercial.</rdfs:comment>
        <rdfs:label xml:lang="en">has commercial permit status</rdfs:label>
        <rdfs:label xml:lang="es">tiene estado de la licencia comercial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasCommercialPermitType -->


