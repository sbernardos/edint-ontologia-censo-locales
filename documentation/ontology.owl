        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente un espacio comercial, con un concepto skos que está en la taxonomía de situación del espacio comercial.</rdfs:comment>
        <rdfs:label xml:lang="en">has commercial space status</rdfs:label>
        <rdfs:label xml:lang="es">tiene situación del espacio comercial</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasIAECode -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasIAECode">
        <rdfs:range>
