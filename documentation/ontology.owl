        <rdfs:comment>It relates an entity, especially a commercial entity or permit, to a skos concept that is in the IAE taxonomy.</rdfs:comment>
        <rdfs:label xml:lang="en">has IAE code</rdfs:label>
        <rdfs:label xml:lang="es">tiene código IAE</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasTerrace -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasTerrace">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#Terrace"/>
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial space, to a terrace it has.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente un espacio comercial, con una terraza que tiene.</rdfs:comment>
        <rdfs:label xml:lang="en">has terrace</rdfs:label>
        <rdfs:label xml:lang="es">tiene terraza</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasTerracePeriod -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#hasTerracePeriod">
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
                        <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/TerracePeriod"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">It relates an entity, especially a terrace, to a skos concept that is in the terrace period taxonomy.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una terrazal, con un concepto skos que está en la taxonomía de periodo de funcionamiento de la terraza.</rdfs:comment>
        <rdfs:label xml:lang="en">has terrace period</rdfs:label>
        <rdfs:label xml:lang="es">tiene periodo de funcionamiento de la terraza</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#issuedTo -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#issuedTo">
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial permit, to the entity, especially a commercial entity, to which (or whom) it is issued.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una licencia comercial, con la entidad, principalmente una entidad comercial, para la que se emite.</rdfs:comment>
        <rdfs:label xml:lang="es">emitida para</rdfs:label>
        <rdfs:label xml:lang="en">issued to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#locatedInZone">
        <rdfs:comment xml:lang="en">It relates en entity, especially a commercial space, event or campaign, to the zone where it is.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente un espacio, campaña o evento comercial, con la zona en la que está.</rdfs:comment>
        <rdfs:label xml:lang="en">located in zone</rdfs:label>
        <rdfs:label xml:lang="es">situado en zona</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#usesSpace -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/comercio/censo-locales#usesSpace">
        <rdfs:comment xml:lang="en">It relates an entity, especially a commercial entity, to a commercial space it uses.</rdfs:comment>
        <rdfs:comment xml:lang="es">Relaciona una entidad, principalmente una entidad comercial, con un espacio comercial que emplea.</rdfs:comment>
        <rdfs:label xml:lang="es">usa espacio</rdfs:label>
        <rdfs:label xml:lang="en">uses space</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#municipio">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio#Municipio"/>
        <rdfs:comment xml:lang="es">Municipio al que pertenece un fenómeno geográfico o una entidad administrativa</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/sector-publico/territorio"/>
        <rdfs:label xml:lang="es">pertenece a municipio</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contienePortal">
        <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#Portal"/>
        <rdfs:comment xml:lang="es">Portal que un fenómeno geográfico contiene (por ejemplo, una vía o un tramo de vía, aunque también puede ser un barrio, distrito, ciudad, etc.)</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero"/>
        <rdfs:label xml:lang="es">contiene portal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#contieneVia -->


