    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:description"/>
        <Literal xml:lang="es">El propósito de esta ontología es proporcionar un vocabulario común para la representación de las entidades y los datos principales relacionados con los establecimientos comerciales de un municipio y sus licencias.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:description"/>
        <Literal xml:lang="en">The purpose of this ontology is to provide a common vocabulary for representing the main entities and data related to a municipality&apos;s commecial spaces and their permits.</Literal>
    </Annotation>
