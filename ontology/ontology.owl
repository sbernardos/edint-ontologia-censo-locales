    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#UrbanElement</IRI>
        <Literal xml:lang="es">Elemento urbano</Literal>
