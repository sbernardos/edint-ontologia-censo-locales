    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CommercialAggregation</IRI>
        <Literal xml:lang="es">La integración de varios establecimientos o puntos de venta en un mismo espacio físico, como centros comerciales o mercados.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <IRI>#CommercialAggregation</IRI>
        <Literal xml:lang="en">The integration of several establishments or points of sale in the same physical space, such as shopping centers or markets.</Literal>
    </AnnotationAssertion>
    <AnnotationAssertion>
        <AnnotationProperty abbreviatedIRI="rdfs:label"/>
        <IRI>#CommercialAggregation</IRI>
