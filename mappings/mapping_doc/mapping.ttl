			rr:template "http://vocab.linkeddata.es/datosabiertos/kos/edint/TerracePeriod/{periodo_funcionamiento}";
			rr:termType rr:IRI
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant schema:floorSize;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "terraza_superficie_m2";
		];
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant schema:maximumAttendeeCapacity;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "terraza_aforo";
			rr:datatype xsd:integer
		];
	];
	rr:predicateObjectMap [
