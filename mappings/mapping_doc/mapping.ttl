		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "numero_sillas";
			rr:datatype xsd:integer
		];
	].


<terraza-geometry_0> a rr:TriplesMap;

	rml:logicalSource [
		a rml:LogicalSource;
		rml:source "entidades_comerciales.csv";
		rml:referenceFormulation ql:CSV

	];
	rr:subjectMap [
		a rr:SubjectMap;
		rr:template "http://vocab.linkeddata.es/datosabiertos/recurso/terraza/geometry/{terraza_id}";
	];
	rr:predicateObjectMap [
		rr:predicateMap [
			a rr:PredicateMap;
			rr:constant geosparql:asWKT;
		];
		rr:objectMap [
			a rr:ObjectMap;
			rml:reference "terraza_wkt";
			rr:datatype geosparql:wktLiteral
		];
	].


