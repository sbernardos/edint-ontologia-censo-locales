@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintterper: <http://vocab.linkeddata.es/datosabiertos/kos/edint/TerracePeriod> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:CommercialSpaceStatus a skos:ConceptScheme ; 
    dct:issued "2026-04-20"^^xsd:date ;
    dct:modified "2026-04-20"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Terrace period"@en ;
    rdfs:label "Periodo de funcionamiento de la terraza"@es;
    dct:title "Concept scheme grouping the terrace periods"@en ;
    dct:title "Esquema de conceptos que agrupa los periodos de funcionamiento de una terraza"@es ;
    skos:hasTopConcept edintkosterper:yearly ;
    skos:hasTopConcept edintkosterper:seasonal .
	
	
#################################################################
#
#    Concepts
#
#################################################################


edintkosterper:yearly a skos:Concept ;
	skos:inScheme edintkos:TerracePeriod ;
	skos:prefLabel "anual"@es ;
	skos:prefLabel "yearly"@en .

edintkosterper:seasonal a skos:Concept ;
	skos:inScheme edintkos:TerracePeriod ;
	skos:prefLabel "estacional"@es ;
	skos:prefLabel "seasonal"@en .
