@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintcompemtype: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialPermitType> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:CommercialPermitType a skos:ConceptScheme ; 
    dct:issued "2026-04-20"^^xsd:date ;
    dct:modified "2026-04-20"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Types of commercial permits"@en ;
    rdfs:label "Tipos de licencias comerciales"@es;
    dct:title "Concept scheme grouping the types of commercial permits"@en ;
    dct:title "Esquema de conceptos que agrupa los tipos de licencias comerciales"@es ;
    skos:hasTopConcept edintcompertype:APAL ;
    skos:hasTopConcept edintcompertype:DRAACT ;
    skos:hasTopConcept edintcompertype:DRAESP ;
	skos:hasTopConcept edintcompertype:CAMTI ;
	skos:hasTopConcept edintcompertype:CAMTC ;
	skos:hasTopConcept edintcompertype:DRVUT .

#################################################################
#
#    Concepts
#
#################################################################

edintcompertype:APAL a skos:Concept ;
	skos:inScheme edintkos:CommercialPermitType ;
#	skos:prefLabel " "@en ;
	skos:prefLabel "APAL"@es .

edintcompertype:DRAACT a skos:Concept ;
	skos:inScheme edintkos:CommercialPermitType ;
#	skos:prefLabel " "@en ;
	skos:prefLabel "DRAACT"@es .

edintcompertype:DRAESP a skos:Concept ;
  skos:inScheme edintkos:CommercialPermitType ;
#	skos:prefLabel " "@en ;
  skos:prefLabel "DRAESP"@es .

edintcompertype:CAMTI a skos:Concept ;
  skos:inScheme edintkos:CommercialPermitType ;
#	skos:prefLabel " "@en ;
  skos:prefLabel "CAMTI"@es .

edintcompertype:CAMTC a skos:Concept ;
  skos:inScheme edintkos:CommercialPermitType ;
#	skos:prefLabel " "@en ;
  skos:prefLabel "CAMTC"@es .

edintcompertype:DRVUT a skos:Concept ;
  skos:inScheme edintkos:CommercialPermitType ;
#	skos:prefLabel " "@en ;
  skos:prefLabel "DRVUT"@es .
