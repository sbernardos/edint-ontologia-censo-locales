@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintkoscomespsit: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialSpaceStatus/> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:CommercialSpaceStatus a skos:ConceptScheme ; 
    dct:issued "2026-04-20"^^xsd:date ;
    dct:modified "2026-04-20"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Status of commercial spaces"@en ;
    rdfs:label "Situación de los espacios comerciales"@es;
    dct:title "Concept scheme grouping the status of commercial spaces"@en ;
    dct:title "Esquema de conceptos que agrupa las situaciones de los espacios comerciales"@es ;
    skos:hasTopConcept edintkoscomespsit:Active ;
    skos:hasTopConcept edintkoscomespsit:Closed ;
    skos:hasTopConcept edintkoscomespsit:ShutDown ;
    skos:hasTopConcept edintkoscomespsit:Free ;
	skos:hasTopConcept edintkoscomespsit:UnderConstruction .

#################################################################
#
#    Concepts
#
#################################################################

edintkoscomespsit:Active a skos:Concept ;
	skos:inScheme edintkos:CommercialSpaceStatus ;
	skos:prefLabel "Activo"@es ;
	skos:prefLabel "Active"@en .

edintkoscomespsit:Closed a skos:Concept ;
	skos:inScheme edintkos:CommercialSpaceStatus ;
	skos:prefLabel "Cerrado"@es ;
	skos:prefLabel "Closed"@en .

edintkoscomespsit:ShutDown a skos:Concept ;
  skos:inScheme edintkos:CommercialSpaceStatus ;
  skos:prefLabel "Clausurado"@es ;
  skos:prefLabel "Shut down"@en .

edintkoscomespsit:Free a skos:Concept ;
  skos:inScheme edintkos:CommercialSpaceStatus ;
  skos:prefLabel "Puesto libre"@es ;
  skos:prefLabel "Free stall"@en .
  
edintkoscomespsit:Taken a skos:Concept ;
  skos:inScheme edintkos:CommercialSpaceStatus ;
  skos:prefLabel "Puesto ocupado"@es ;
  skos:prefLabel "Taken stall"@en .


edintkoscomespsit:UnderConstruction a skos:Concept ;
  skos:inScheme edintkos:CommercialSpaceStatus ;
  skos:prefLabel "En obras"@es ;
  skos:prefLabel "Under construction"@en .
