@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .

@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .
@prefix edintcompersta: <http://vocab.linkeddata.es/datosabiertos/kos/edint/CommercialPermitStatus> .

#################################################################
#
#    Concept Scheme
#
#################################################################

edintkos:CommercialPermitStatus a skos:ConceptScheme ; 
    dct:issued "2026-04-20"^^xsd:date ;
    dct:modified "2026-04-20"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Status of commercial permit"@en ;
    rdfs:label "Estado de tramitación de la licencia de comercio"@es ;
    dct:title "Concept scheme grouping status of commercial permits"@en ;
    dct:title "Esquema de conceptos que agrupa los estados de tramitación de la licencia de comercio"@es ;
    skos:hasTopConcept edintkoscompersta:Granted ;
    skos:hasTopConcept edintkoscompersta:Denied ;
    skos:hasTopConcept edintkoscompersta:InProcess ;
	skos:hasTopConcept edintkoscompersta:Expired .
	

#################################################################
#
#    Concepts
#
#################################################################

edintkoscompersta:Granted a skos:Concept ;
	skos:inScheme edintkos:CommercialPermitStatus ;
 	skos:prefLabel "Concedida"@es ;
	skos:prefLabel "Granted"@en .

edintkoscompersta:Denied a skos:Concept ;
	skos:inScheme edintkos:CommercialPermitStatus ;
   skos:prefLabel "Denegada"@es ;
   skos:prefLabel "Denied"@en .

edintkoscompersta:InProcess a skos:Concept ;
  skos:inScheme edintkos:CommercialPermitStatus ;
  skos:prefLabel "En trámite"@es ;
  skos:prefLabel "In process"@en .

edintkoscompersta:Expired a skos:Concept ;
  skos:inScheme edintkos:CommercialPermitStatus ;
  skos:prefLabel "Caducada"@es ;
  skos:prefLabel "Expired"@en .